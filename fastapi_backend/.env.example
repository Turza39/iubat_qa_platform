# Database Configuration
# Choose database engine: 'sqlite' (development) or 'postgresql' (production)
DB_ENGINE=sqlite
DB_NAME=iubat_qa_db
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432

# For SQLite (used if DB_ENGINE=sqlite)
SQLITE_URL=sqlite:///./iubat_qa.db

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# App Configuration
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,api.example.com

# CORS Configuration (allow frontend to communicate)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Media and Static Files
MEDIA_URL=/media/
MEDIA_ROOT=./media
STATIC_URL=/static/
STATIC_ROOT=./static

# Timezone
TIMEZONE=Asia/Dhaka

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Optional SMTP configuration for async emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@iubatqa.local

# ============================================================================
# CLOUD SERVICES CONFIGURATION (PHASE 1)
# ============================================================================

# Supabase Configuration (File Storage)
# Get these from your Supabase project: https://supabase.com
# 1. Create a project → Settings → API
# 2. Create a storage bucket named "verification-images"
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ACCESS_KEY=your-anon-key
SUPABASE_SECRET_KEY=your-service-role-key
SUPABASE_BUCKET=verification-images

# Upstash Redis (for production - works across replicas)
# Get this from your Upstash console: https://console.upstash.com
REDIS_URL=redis://default:your-password@your-redis.upstash.io:6379/0
CELERY_BROKER_URL=redis://default:your-password@your-redis.upstash.io:6379/1
CELERY_RESULT_BACKEND=redis://default:your-password@your-redis.upstash.io:6379/2

# ============================================================================
# RATE LIMITING (Optional)
# ============================================================================
RATE_LIMIT_ENABLED=False
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60
